{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kastel-stack.org/schemas/clarify_intent.schema.json",
  "title": "Clarify Intent",
  "type": "object",
  "required": ["id", "question", "uncertainty", "next_decision"],
  "properties": {
    "id": { "type": "string" },
    "question": { "type": "string" },
    "uncertainty": { "type": "string" },
    "next_decision": { "type": "string" },
    "source_of_truth": { "type": "string" },
    "clarification_type": {
      "enum": [
        "sensor",
        "semantic",
        "source_of_truth",
        "niche",
        "risk",
        "portability"
      ]
    },
    "linked_dna": { "type": "string" },
    "adaptive_field": { "type": "string" },
    "decision_relevance": { "type": "string" }
  },
  "additionalProperties": false
}

