{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kastel-stack.org/schemas/state_niche_fit.schema.json",
  "title": "State Niche Fit",
  "type": "object",
  "required": ["internal_readiness", "external_legibility", "observable_outcome", "supervision_capacity"],
  "properties": {
    "internal_readiness": { "type": "number", "minimum": 0, "maximum": 1 },
    "external_legibility": { "type": "number", "minimum": 0, "maximum": 1 },
    "observable_outcome": { "type": "number", "minimum": 0, "maximum": 1 },
    "supervision_capacity": { "type": "number", "minimum": 0, "maximum": 1 },
    "fit_state": {
      "enum": [
        "in_band",
        "clarify_first",
        "maintain_first",
        "protect_first",
        "overloaded",
        "locked_in",
        "spun_out",
        "cascade_forming"
      ]
    },
    "immune_system_risk": { "type": "number", "minimum": 0, "maximum": 1 },
    "operator_workload": { "type": "number", "minimum": 0, "maximum": 1 },
    "source_of_truth_defined": { "type": "boolean" },
    "delayed_review_defined": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}

